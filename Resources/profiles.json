      "builtIn": true
    },
    {
      "id": "claude-code",
      "displayName": "Claude Code",
      "detectionMarkers": ["claude code", "esc to interrupt"],
      "attachTemplate": "{path} ",
      "builtIn": true
    },
    {
      "id": "codex",
      "displayName": "Codex",
      "detectionMarkers": ["openai codex", "codex"],
      "attachTemplate": "{path} ",
      "builtIn": true
    },
    {
      "id": "aider",
      "displayName": "aider",
      "detectionMarkers": ["aider"],
      "attachTemplate": "/add {path}\n",
      "builtIn": true
    },
    {
      "id": "gemini-cli",
      "displayName": "Gemini CLI",
      "detectionMarkers": ["gemini"],
      "attachTemplate": "{path} ",
      "builtIn": true
    },
    {
      "id": "opencode",
      "displayName": "opencode",
      "detectionMarkers": ["opencode"],
      "attachTemplate": "{path} ",
      "builtIn": true
    },
    {
      "id": "hermes",
      "displayName": "Hermes",
      "detectionMarkers": ["hermes"],
      "attachTemplate": "{path} ",
      "builtIn": true
    }
  ],
  "multiplexers": [
    {
      "id": "tmux",
      "displayName": "tmux",
      "listSessionsCommand": "tmux list-sessions -F '#S'",
      "attachTemplate": "tmux attach -t {target} || tmux new -s {target}",
      "currentTargetCommand": "tmux list-sessions -F '#{session_attached} #{session_activity} #{session_name}' | sort -rnk2 | awk '$1>0{print $3; exit}'",
      "mouseHintCommand": "tmux set -g mouse on",
      "builtIn": true
    },
    {
      "id": "zellij",
      "displayName": "zellij",
      "listSessionsCommand": "zellij list-sessions -s",
      "attachTemplate": "zellij attach {target}",
      "currentTargetCommand": "printf '%s' \"$ZELLIJ_SESSION_NAME\"",
      "mouseHintCommand": null,
      "builtIn": true
    },
    {
      "id": "screen",
      "displayName": "screen",
      "listSessionsCommand": "screen -ls | grep -oE '[0-9]+\\.[^[:space:]]+'",
      "attachTemplate": "screen -r {target} || screen -x {target}",
      "currentTargetCommand": "screen -ls | grep -E '\\(Attached\\)' | grep -oE '[0-9]+\\.[^[:space:]]+' | head -1",
      "mouseHintCommand": null,
      "builtIn": true
    },
    {
      "id": "dtach",
      "displayName": "dtach",
      "listSessionsCommand": null,
      "attachTemplate": "dtach -a {target}",
      "currentTargetCommand": null,
      "mouseHintCommand": null,
      "builtIn": true
    },
    {
      "id": "none",
      "displayName": "None (raw shell)",
      "listSessionsCommand": null,
      "attachTemplate": null,
      "currentTargetCommand": null,
      "mouseHintCommand": null,
      "builtIn": true
    }
  ]
}
